DirectoryIndex index.html
Options -MultiViews

RewriteEngine On
RewriteBase /

# Let existing files and directories be served directly.
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Route all other requests to the SPA entrypoint.
RewriteRule ^ index.html [L]

# Ensure static assets are served with expected MIME types.
AddType text/javascript .js .mjs
AddType text/css .css

# Force UTF-8 to avoid charset-related text corruption.
AddCharset UTF-8 .html .js .mjs .css